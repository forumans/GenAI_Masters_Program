# Environment variables for AutoGen Intelligent User Feedback Analysis System

# OpenAI API Key (required for AutoGen agents)
OPENAI_API_KEY=<your_openai_api_key_here>

# OpenAI Model Configuration
OPENAI_MODEL_NAME=gpt-3.5-turbo

# AutoGen Configuration
AUTOGEN_USE_DOCKER=false
AUTOGEN_MAX_CONSECUTIVE_AUTO_REPLY=10
AUTOGEN_TIMEOUT=120

# Classification Thresholds
CLASSIFICATION_CONFIDENCE_THRESHOLD=0.7
BUG_SEVERITY_THRESHOLD=0.8
FEATURE_PRIORITY_THRESHOLD=0.6

# File Paths (local to project directory)
DATA_DIR=data
OUTPUT_DIR=data
LOG_DIR=logs

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# Agent Configuration
DEFAULT_AGENT_TEMPERATURE=0.1
MAX_AGENT_ITERATIONS=5
