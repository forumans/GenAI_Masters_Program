# Environment variables for Intelligent User Feedback Analysis System

# OpenAI API Key (required for CrewAI and LangChain)
OPENAI_API_KEY=<your_openai_api_key_here>

# OpenAI Model Configuration
OPENAI_MODEL_NAME=gpt-3.5-turbo

# Classification Thresholds
CLASSIFICATION_CONFIDENCE_THRESHOLD=0.7
BUG_SEVERITY_THRESHOLD=0.8
FEATURE_PRIORITY_THRESHOLD=0.6

# File Paths (local to project directory)
DATA_DIR=data
OUTPUT_DIR=data
LOG_DIR=logs

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# Streamlit Configuration
STREAMLIT_HOST=localhost
STREAMLIT_PORT=8501

# Processing Configuration
MAX_BATCH_SIZE=10
PROCESSING_TIMEOUT=300
ENABLE_QUALITY_CHECK=true
