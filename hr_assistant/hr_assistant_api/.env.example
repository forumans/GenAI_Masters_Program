# ========================================
# REQUIRED ENVIRONMENT VARIABLES
# ========================================
# Copy this file to .env and fill in all values
# The application will NOT start without these values

# Database
DATABASE_URL=postgresql://hr_assistant_user:<your-database-password>@localhost:5432/hr_assistant_db

# OpenAI
OPENAI_API_KEY=<your-openai-api-key>

# App
SECRET_KEY=your-secret-key-change-in-production
DEBUG=true

# HR Policies
HR_POLICIES_PATH= ./../hr_policies/hr_policies.pdf

# OpenAI Model Name
OPENAI_MODEL_NAME=gpt-3.5-turbo

# OpenAI Text Embedding Model Name
EMBEDDING_MODEL_NAME=text-embedding-3-small

# Chroma Vector DB Location
CHROMA_PERSIST_DIR=./chroma_data
CHROMA_COLLECTION_NAME=hr_policies_collection

CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_data
